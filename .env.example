# deploy-docker.ps1 creates .env automatically. Copy this file only for manual deployment.
POSTGRES_DB=imagegen
POSTGRES_USER=imagegen
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
# Optional. When empty, SECRET_KEY also encrypts provider API keys. Keep it stable after first save.
CONFIG_ENCRYPTION_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Docker Hub is not directly reachable on some company networks. Both images are configurable.
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:17-alpine

# Optional bootstrap values. Configure providers in the administrator UI after login.
GPT_CHAT_API_BASE_URL=
GPT_CHAT_API_KEY=
GPT_CHAT_MODEL=gpt-5.6-sol
GPT_CHAT_REASONING_EFFORT=max

# Optional image-channel bootstrap values.
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
LUCEN_API_BASE_URL=https://lucen.plus
LUCEN_API_KEY=

IMAGEGEN_PORT=18081
COOKIE_SECURE=false
