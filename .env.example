# deploy-docker.ps1 会自动创建 .env；仅手动部署时复制此文件。
POSTGRES_DB=imagegen
POSTGRES_USER=imagegen
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
# 可选。留空时使用 SECRET_KEY 加密上游 API Key；首次保存后必须保持稳定。
CONFIG_ENCRYPTION_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# 某些公司网络无法直接访问 Docker Hub；两个镜像地址都可配置。
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:17-alpine

# 可选的初始化值。登录后请在管理后台配置上游服务。
GPT_CHAT_API_BASE_URL=
GPT_CHAT_API_KEY=
GPT_CHAT_MODEL=gpt-5.6-sol
GPT_CHAT_REASONING_EFFORT=max

# 可选的生图渠道初始化值。
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
LUCEN_API_BASE_URL=https://lucen.plus
LUCEN_API_KEY=

IMAGEGEN_PORT=18081
IMAGEGEN_BIND_HOST=127.0.0.1
COOKIE_SECURE=false
# 仅当请求必经一个可信反向代理时启用。
TRUST_PROXY_HEADERS=false

# Optional Lucida matting service (compose service: http://lucida:8000)
LUCIDA_IMAGE=snow-ai-studio-lucida:latest
LUCIDA_MATTING_URL=
LUCIDA_MATTING_MODEL=lucida
LUCIDA_MATTING_TIMEOUT_SECONDS=120
# CUDA torch index for docker/lucida (use .../cpu for CPU-only hosts)
LUCIDA_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu124
LUCIDA_PRELOAD_MODEL=1
